---
interface Category extends String {}
interface TechItem extends String {}

const {
  title,
  subtitle,
  categories = [] as Category[],
  banner,
  description,
  github,
  tech = [] as TechItem[],
} = Astro.props;
---

<section class="max-w-5xl mx-auto py-5 px-4 sm:px-6 lg:px-40">
  <a data-aos="fade-in" data-aos-duration="800" href="/" class="group w-fit text-white/75 flex items-center gap-2 text-sm mb-4">
    <span class="group-hover:-translate-x-1 transition-transform duration-200">←</span>
    <span>Volver</span>
  </a>

  <!-- Categories -->
  <div data-aos="fade-in" data-aos-duration="800" data-aos-delay="100" class="flex gap-2 mb-6">
    {
      categories.map((cat: Category) => (
        <span class="font-jetbrains px-3 py-1 bg-interactive border border-border text-white/75 text-sm">
          {cat}
        </span>
      ))
    }
  </div>

  <div data-aos="fade-in" data-aos-duration="800" data-aos-delay="200" class="h-64 overflow-hidden mb-4 border border-border rounded bg-surface flex items-center justify-center p-8">
    <img loading="lazy" width="1920" height="1080" alt=`Proyecto ${title}` src={banner} class="w-full h-full object-contain" />
  </div>

  <h1 data-aos="fade-in" data-aos-duration="800" data-aos-delay="100" class="font-jetbrains text-title text-4xl font-bold mb-2">{title}</h1>

  <h2 data-aos="fade-in" data-aos-duration="800" data-aos-delay="250" class="font-jetbrains text-title text-xl font-medium mb-6">{subtitle}</h2>

  <p data-aos="fade-in" data-aos-duration="800" data-aos-delay="300" class="font-light text-white/75 mb-6">{description}</p>

  <a data-aos="fade-in" data-aos-duration="800" href={github} target="_blank"
    class="font-jetbrains flex items-center gap-2 w-fit px-4 py-3 text-black text-sm rounded bg-white border-white hover:bg-white/80 transition mb-10">
    
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
    </svg>
    Ver en GitHub
  </a>

  <!-- Features -->
  <h3 data-aos="fade-in" data-aos-duration="800" class="font-jetbrains text-title text-xl font-semibold mb-3">Características Principales</h3>
  <div class="mb-10 text-white">
    <slot name="features" />
  </div>

  <!-- Tech Stack -->
  <h3 data-aos="fade-in" data-aos-duration="800" class="font-jetbrains text-title text-xl font-semibold mb-3">Tecnologías Utilizadas</h3>
  <div data-aos="fade-in" data-aos-duration="800" data-aos-delay="100" class="flex flex-wrap gap-2 mb-10">
    {
      tech.map((t: TechItem) => (
        <span class="font-jetbrains px-3 py-1 bg-interactive border border-border text-white/75 text-sm">
          {t}
        </span>
      ))
    }
  </div>

  <!-- Gallery -->
  <h4 data-aos="fade-in" data-aos-duration="800" class="font-jetbrains text-title text-xl font-semibold mb-4">Galería de Imágenes</h4>
  <div data-aos="fade-in" data-aos-duration="800" data-aos-delay="100" class="mb-10">
    <slot name="gallery" />
  </div>
</section>