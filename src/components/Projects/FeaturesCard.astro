---
const { title, description } = Astro.props;
---

<div class="flex items-start gap-3">
  <span class="mt-1.5 w-2 h-2 rounded-full bg-white shadow-[0_0_8px_1px_rgba(255,255,255,0.5)]"></span>
  <div>
    <span class="font-jetbrains text-white font-semibold">{title}</span>
    <p class="text-white/75 text-sm font-light leading-relaxed">{description}</p>
  </div>
</div>