---
const { images } = Astro.props;
const imagesJson = JSON.stringify(images);
---

<div class="gallery-container max-w-4xl mx-auto" data-gallery-images={imagesJson}>
  <!-- Imagen principal -->
  <div id="gallery-wrapper" class="relative overflow-hidden shadow-lg rounded border border-border bg-surface">
    <img
      loading="lazy"
      id="gallery-image" 
      src={images[0].src} 
      alt={images[0].alt}
      class="w-full h-auto object-contain"
    />
    
    <!-- Botón anterior -->
    <button 
      id="prev-btn"
      class="absolute left-2 top-1/2 -translate-y-1/2 bg-interactive hover:bg-interactive/80 text-white p-2 rounded transition-all disabled:opacity-30 disabled:cursor-not-allowed md:left-4 cursor-pointer"
      aria-label="Imagen anterior"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    
    <!-- Botón siguiente -->
    <button 
      id="next-btn"
      class="absolute right-2 top-1/2 -translate-y-1/2 bg-interactive hover:bg-interactive/80 text-white p-2 rounded transition-all disabled:opacity-30 disabled:cursor-not-allowed md:right-4 cursor-pointer"
      aria-label="Imagen siguiente"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>
  
  <!-- Contador de imágenes -->
  <div class="text-center text-sm mt-4 font-jetbrains text-white/50">
    <span id="current-index">1</span> / <span id="total-images">{images.length}</span>
  </div>
</div>

<script>
  import { initGallery } from '../../scripts/gallery';
  
  const container = document.querySelector('[data-gallery-images]');
  const imagesData = container?.getAttribute('data-gallery-images');
  const images = imagesData ? JSON.parse(imagesData) : [];
  
  initGallery(images);
</script>