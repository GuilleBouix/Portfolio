---
import ProjectCard from './Projects/ProjectCard.astro';
---

<section id="projects">
    <div data-aos="zoom-in" data-aos-duration="800" class="flex justify-between items-center gap-2 py-5 mx-auto max-w-5xl px-4 sm:px-6 lg:px-40">
        <h2 class="font-jetbrains text-title font-bold text-xl">
            Mis Proyectos
        </h2>
    </div>

    <div class="overflow-hidden grid grid-cols-1 sm:grid-cols-2 gap-6 mx-auto max-w-5xl px-4 sm:px-6 lg:px-40">
        <ProjectCard
            title="Yagua"
            type="Desktop App"
            description="Software open-source para procesamiento de imágenes con compresión, conversión de formatos, eliminación de fondo con IA y extracción de paletas de colores."
            image="/img/projects/yagua.webp"
            tech={["Python", "CustomTkinter", "Pillow", "rembg", "piexif", "Pytest"]}
            link="/projects/yagua-image-processor"
            github="https://github.com/GuilleBouix/Yagua-Image-Processor"
        />

        <ProjectCard
            title="Textly Chat"
            type="Full-Stack"
            description="Chat privado por salas entre dos usuarios con asistencia de IA para mejorar redacción, reformular ideas y traducir mensajes en tiempo real."
            image="/img/projects/textly-chat.webp"
            tech={["Next.js", "React", "TypeScript", "Tailwind CSS", "Gemini Flash API"]}
            link="/projects/textly-chat"
            github="https://github.com/GuilleBouix/Textly-Chat"
        />

        <ProjectCard
            title="Finence"
            type="Full-Stack"
            description="Finence es una aplicacion web para gestionar tus finanzas personales. Controla tus ingresos y gastos de manera sencilla, visualiza tu historial financiero y manten un registro detallado de todas tus transacciones."
            image="/img/projects/finence.webp"
            tech={["React", "Vite", "TypeScript", "Zustand", "Tailwind CSS", "Supabase"]}
            link="/projects/finence"
            github="https://github.com/GuilleBouix/Finence"
        />

        <ProjectCard
            title="BeardCut"
            type="Full-Stack"
            description="BeardCut — Turnos Barbería es una landing page limpia respaldada por un panel de administración en Flask, donde el dueño puede gestionar reservas, configurar horarios de atención, actualizar información del negocio y controlar los servicios disponibles."
            image="/img/projects/beardcut.webp"
            tech={["Astro", "JavaScript", "HTML", "Tailwind CSS", "Python", "Flask", "PostgreSQL"]}
            link="/projects/beardcut"
            github="https://github.com/GuilleBouix/Turnos-Barberia"
        />

        <ProjectCard
            title="Sistema GCA"
            type="Desktop App"
            description="GCA es un sistema de gestión y control de asistencia que ayuda a las empresas a registrar ingresos del personal, horarios y actividad diaria de forma simple y eficiente."
            image="/img/projects/sistema-gca.webp"
            tech={["C#", "WinForms", "SQLite"]}
            link="/projects/sistema-gca"
            github="https://github.com/GuilleBouix/Sistema-GCA"
        />

        <ProjectCard
            title="Last Dying Website"
            type="Frontend"
            description="Sitio web oficial de Last Dying, un proyecto solitario de metal instrumental. Incluye lanzamiento destacado, discografía completa con previews, enlaces externos de compra, biografía, formulario de contacto y enlaces a plataformas sociales. Desarrollado con foco en rendimiento, eficiencia y SEO."
            image="/img/projects/last-dying.webp"
            tech={["Astro", "JavaScript", "HTML", "Tailwind CSS"]}
            link="/projects/last-dying-website"
            github="https://github.com/GuilleBouix/Last-Dying-Official-Website"
        />

        <ProjectCard
            title="Training Plus"
            type="Full-Stack"
            description="Training+ es un sistema web diseñado para la gestión de entrenamientos personalizados, permitiendo una interacción eficiente entre entrenadores y alumnos. Lo desarrollé como proyecto final de tesis."
            image="/img/projects/training-plus.webp"
            tech={["Python", "Flask", "JavaScript", "HTML", "CSS", "SQLite"]}
            link="/projects/training-plus"
            github="https://github.com/GuilleBouix/TrainingPlus-Tesis"
        />

    </div>
</section>