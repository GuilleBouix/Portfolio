---
const phone = "5493755653522";
const message = "Hola Guille! Quisiera hacer una consulta";
---

<a
  href={`https://wa.me/${phone}?text=${encodeURIComponent(message)}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="WhatsApp"
  class="
    flex
    fixed bottom-6 right-6 z-50
    h-11 w-11 md:h-14 md:w-14
    items-center justify-center
    rounded-full
    bg-[#25D366]
    text-white
    transition-all
    hover:scale-110
    active:scale-95
  "

>
  <img
    src="/img/icons/whatsapp.svg"
    alt="WhatsApp"
    class="h-5 w-5 md:h-7 md:w-7 filter invert"
  />
</a>