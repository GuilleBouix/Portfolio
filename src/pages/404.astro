---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="404 - Página no encontrada">
  <div class="flex flex-col min-h-screen">
    <header>
      <Navbar />
    </header>

    <main id="content" class="flex-1 flex items-center justify-center px-4">
      <div class="text-center" data-aos="fade-in" data-aos-duration="800">
        <h1 class="font-jetbrains text-4xl leading-none font-bold text-title mb-4">404</h1>
        <p class="font-jetbrains text-2xl text-white/75 mb-2">Página no encontrada</p>
        <p class="text-white/50 mb-8">La página que buscas no existe o fue movida.</p>
        <a 
          href="/" 
          class="inline-flex items-center gap-2 px-6 py-3 font-jetbrains text-black text-sm rounded bg-white border-white hover:bg-white/80 transition"
        >
          <span>←</span>
          <span>Volver al inicio</span>
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
