---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ProjectPage from "../../components/Projects/ProjectPage.astro";
import Gallery from "../../components/Projects/Gallery.astro";
import FeaturesCard from "../../components/Projects/FeaturesCard.astro";

const myImages = [
  { src: "/img/projects/trainingplus/1.webp", alt: "Primera imagen" },
  { src: "/img/projects/trainingplus/2.webp", alt: "Segunda imagen" },
  { src: "/img/projects/trainingplus/3.webp", alt: "Tercera imagen" },
  { src: "/img/projects/trainingplus/4.webp", alt: "Cuarta imagen" },
  { src: "/img/projects/trainingplus/5.webp", alt: "Quinta imagen" },
  { src: "/img/projects/trainingplus/6.webp", alt: "Sexta imagen" },
  { src: "/img/projects/trainingplus/7.webp", alt: "Séptima imagen" },
  { src: "/img/projects/trainingplus/8.webp", alt: "Octava imagen" }
]
---

<Layout>
  <header>
    <Navbar />
  </header>

  <main id="content">
    <ProjectPage
      title="Training Plus"
      subtitle="Sistema de Gestión y Seguimiento de Entrenamientos Personalizados"
      categories={["Full-Stack", "Proyecto Final"]}
      banner="/img/projects/training-plus.webp"
      description="Plataforma web desarrollada como proyecto de tesis para la carrera de Analista Programador (Agosto 2025), orientada a establecer un vínculo directo y continuo entre entrenadores y alumnos. La aplicación permite a los entrenadores crear y administrar rutinas de entrenamiento personalizadas, mientras que los alumnos pueden registrar y seguir su progreso mediante métricas en tiempo real. El sistema facilita el análisis del rendimiento por parte de ambos, permitiendo realizar ajustes sobre los planes de entrenamiento y fomentando una colaboración más cercana, asegurando que las rutinas se mantengan efectivas y optimizadas a lo largo del tiempo."
      github="https://github.com/GuilleBouix/TrainingPlus-Tesis"
      tech={["Python", "Flask", "JavaScript", "HTML", "CSS", "SQLite"]}
    >

      <!-- Galería -->
      <div slot="gallery">
        <Gallery images={myImages} />
      </div>

      <!-- Funcionalidades -->
      <ul slot="features" class="list-disc list-inside space-y-3 mt-2">
        <FeaturesCard title="Dashboard Completo" description="Estadísticas en tiempo real, métricas de progreso y análisis de rendimiento." />
        <FeaturesCard title="Gestión de Rutinas" description="Rutinas por semanas, días y ejercicios específicos." />
        <FeaturesCard title="Registro de Entrenamientos" description="Seguimiento de series, repeticiones y pesos con historial." />
        <FeaturesCard title="Autenticación y Vinculación" description="Roles para entrenadores y alumnos con proceso de vinculación." />
        <FeaturesCard title="Gráficos de Progreso" description="Visualización de rendimiento y récords personales." />
        <FeaturesCard title="Perfil de Usuario Editable" description="Datos personales, foto de perfil y preferencias." />
      </ul>

    </ProjectPage>
  </main>
  <Footer />
</Layout>