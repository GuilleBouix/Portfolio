---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

import ProjectPage from "../../components/Projects/ProjectPage.astro";
import Gallery from "../../components/Projects/Gallery.astro";
import FeaturesCard from "../../components/Projects/FeaturesCard.astro";

const myImages = [
  { src: "/img/projects/finence/1.webp", alt: "Primera captura" },
  { src: "/img/projects/finence/2.webp", alt: "Segunda captura" },
  { src: "/img/projects/finence/3.webp", alt: "Tercera captura" },
  { src: "/img/projects/finence/4.webp", alt: "Cuarta captura" }
]
---

<Layout>
  <header>
    <Navbar />
  </header>
  
  <main id="content">
    <ProjectPage
      title="Finence"
      subtitle="Control de finanzas personales"
      categories={["Full-Stack"]}
      banner="/img/projects/finence.webp"
      description="Finence es una aplicación web de finanzas personales que permite a los usuarios registrar ingresos y gastos, consultar su historial de transacciones y visualizar balances y tendencias mediante gráficos interactivos, todo con datos actualizados en tiempo real y autenticación segura con Supabase. Está desarrollada con un stack moderno (React, TypeScript, Vite, TailwindCSS, Zustand y Recharts) y organizada con una arquitectura modular y mantenible, pensada para ser rápida, responsive y fácil de escalar o extender con nuevas funcionalidades."
      github="https://github.com/GuilleBouix/Finence"
      tech={["React", "Vite", "TypeScript", "Zustand", "Tailwind CSS", "Supabase"]}
    >

      <!-- Gallery -->
      <div slot="gallery">
        <Gallery images={myImages} />
      </div>

      <!-- Features -->
    <div slot="features" class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        <FeaturesCard
            title="Registro de transacciones"
            description="Permite agregar, editar y eliminar ingresos y gastos de forma rápida, manteniendo un control detallado de cada movimiento financiero."
        >
            <svg slot="icon" class="w-6 h-6 text-sky-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17.345a4.76 4.76 0 0 0 2.558 1.618c2.274.589 4.512-.446 4.999-2.31.487-1.866-1.273-3.9-3.546-4.49-2.273-.59-4.034-2.623-3.547-4.488.486-1.865 2.724-2.899 4.998-2.31.982.236 1.87.793 2.538 1.592m-3.879 12.171V21m0-18v2.2"/>
            </svg>

        </FeaturesCard>

        <FeaturesCard
            title="Resumen financiero"
            description="Visualiza automáticamente el total de ingresos, gastos y balance general actualizado al instante a medida que registras operaciones."
        >
            <svg slot="icon" class="w-6 h-6 text-sky-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M6 14h2m3 0h5M3 7v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1Z"/>
            </svg>
        </FeaturesCard>

        <FeaturesCard
            title="Historial detallado"
            description="Consulta todas tus transacciones en una lista organizada con fechas, montos y categoría para facilitar el seguimiento de tus finanzas."
        >
            <svg slot="icon" class="w-6 h-6 text-sky-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
        </FeaturesCard>

        <FeaturesCard
            title="Gráficos y estadísticas"
            description="Estadísticas y visualizaciones interactivas que muestran la evolución de tus ingresos y gastos para detectar patrones y hábitos financieros."
        >
            <svg slot="icon" class="w-6 h-6 text-sky-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v15a1 1 0 0 0 1 1h15M8 16l2.5-5.5 3 3L17.273 7 20 9.667"/>
            </svg>

        </FeaturesCard>

        <FeaturesCard
            title="Autenticación segura"
            description="Cada usuario accede a sus propios datos mediante login protegido con Supabase Auth, garantizando privacidad y seguridad."
        >
            <svg slot="icon" class="w-6 h-6 text-sky-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14v3m-3-6V7a3 3 0 1 1 6 0v4m-8 0h10a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1Z"/>
            </svg>
        </FeaturesCard>
    </div>

    </ProjectPage>
  </main>
  
  <Footer />
</Layout>